# Semtech UDP listener for sx1302 packet forwarder
SEMTECH_LISTEN_HOST=0.0.0.0
SEMTECH_LISTEN_PORT=1700

# KISS endpoint consumed by your MeshCore-side host/client
KISS_LISTEN_HOST=127.0.0.1
KISS_LISTEN_PORT=8001

# Default TX radio params used when sending frames out via WM1302
TX_FREQ_HZ=868100000
TX_BW_HZ=125000
TX_SF=10
TX_CR=5
TX_POWER_DBM=14

# Built-in repeater behavior in bridge (1=enabled, 0=disabled)
AUTO_REPEAT_ENABLED=1
AUTO_REPEAT_MIN_DELAY_MS=250
AUTO_REPEAT_MAX_DELAY_MS=1250
AUTO_REPEAT_HOLDOFF_SECONDS=60
AUTO_REPEAT_REQUIRE_CRC_OK=1
AUTO_REPEAT_MIN_RSSI=-127
AUTO_REPEAT_MIN_SNR_X4=-128

# Periodic beacon transmission (1=enabled, 0=disabled)
BEACON_ENABLED=0
BEACON_INTERVAL_SECONDS=60
BEACON_MESSAGE=MeshCore Beacon

LOG_LEVEL=INFO
